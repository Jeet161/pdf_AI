# ── Database ──────────────────────────────────────────────────────────────────
# Supabase "Transaction" pooler URL (port 6543).
# Go to: Supabase Dashboard → Project → Settings → Database → Connection pooling
# Use Transaction mode and add  ?sslmode=require  at the end.
DATABASE_URL=postgresql+psycopg://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Free key from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── Storage ───────────────────────────────────────────────────────────────────
# On Render this is ephemeral; consider switching to Supabase Storage later.
STORAGE_DIR=./storage

# ── Shared secret with Next.js ────────────────────────────────────────────────
# Must match INTERNAL_API_SECRET in frontend/.env.local exactly.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_SECRET=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Your Vercel deployment URL (e.g. https://pdf-ai-delta.vercel.app)
ALLOWED_ORIGIN=
