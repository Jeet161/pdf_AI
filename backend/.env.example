# Database connection (matches docker-compose.yml values)
DATABASE_URL=ur db

# Google AI Studio (Gemini) API key - get one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Local file storage path for uploaded PDFs
STORAGE_DIR=./storage

# Shared secret with the Next.js frontend - must match INTERNAL_API_SECRET
# in frontend/.env.local exactly
INTERNAL_API_SECRET=your_shared_secret_here
