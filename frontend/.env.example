# ── Backend URL ───────────────────────────────────────────────────────────────
# Your Render deployment URL (no trailing slash)
NEXT_PUBLIC_API_URL=https://<your-render-service>.onrender.com

# ── Better Auth ───────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=
# Your Vercel deployment URL (no trailing slash)
BETTER_AUTH_URL=https://<your-app>.vercel.app
NEXT_PUBLIC_APP_URL=https://<your-app>.vercel.app

# ── Database (Better Auth uses this directly with the Node pg driver) ─────────
# Supabase "Session" pooler URL (port 5432, no +psycopg suffix).
# Go to: Supabase Dashboard → Project → Settings → Database → Connection pooling
# Use Session mode (port 5432).
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ── Shared secret with FastAPI backend ────────────────────────────────────────
# Must match INTERNAL_API_SECRET in backend/.env exactly.
INTERNAL_API_SECRET=
